# Get your API key from https://resend.com/api-keys (free tier: 100 emails/day)
RESEND_API_KEY=re_xxxxxxxxxxxx

# The email address that receives client selections
RECIPIENT_EMAIL=your-email@example.com

# Optional: custom from address (requires domain verification in Resend)
